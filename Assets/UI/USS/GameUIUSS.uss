.root {
    width: 100%;
    height: 100%;
    padding: 16px;
}

.timer-label {
    position: absolute;
    top: 0;
    left: 50%;
    translate: -50% 0;
    font-size: 32px;
    -unity-font-style: bold;
    text-shadow: 2px 2px black;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: black;
}